// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Multi-tenant client
model Client {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  projects      Project[]
  videoAnalyses VideoAnalysis[]
  executionResults ExecutionResult[]

  @@map("clients")
}

// User model with roles
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      UserRole @default(QA_ENGINEER)
  clientId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client       Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  testCases    TestCase[]
  results      ExecutionResult[]
  skillLogs    SkillLog[]

  @@index([clientId])
  @@map("users")
}

enum UserRole {
  QA_ENGINEER
  TEST_LEAD
  ADMIN
}

// Project model with framework and designPattern fields
model Project {
  id            String   @id @default(cuid())
  name          String
  description   String?
  clientId      String
  framework     String   // e.g., Cypress, Playwright, Selenium
  designPattern String   // e.g., Page Object Model, BDD
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  client    Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  testCases TestCase[]
  defects   Defect[]

  @@index([clientId])
  @@map("projects")
}

// Core TestCase model
model TestCase {
  id          String   @id @default(cuid())
  name        String
  description String?
  projectId   String
  userId      String
  status      TestCaseStatus @default(ACTIVE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project         Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  executionResults ExecutionResult[]
  defects         Defect[]

  @@index([projectId])
  @@index([userId])
  @@map("test_cases")
}

enum TestCaseStatus {
  ACTIVE
  DEPRECATED
  ARCHIVED
}

// ExecutionResult model
model ExecutionResult {
  id           String   @id @default(cuid())
  testCaseId   String
  userId       String
  status       ExecutionStatus
  duration     Int?     // in milliseconds
  errorMessage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  testCase TestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  defects  Defect[]

  @@index([testCaseId])
  @@index([userId])
  @@map("execution_results")
}

enum ExecutionStatus {
  PASSED
  FAILED
  SKIPPED
  BLOCKED
  IN_PROGRESS
}

// Defect model
model Defect {
  id               String   @id @default(cuid())
  title            String
  description      String?
  testCaseId       String
  projectId        String
  executionResultId String?
  severity         DefectSeverity
  status           DefectStatus @default(OPEN)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  testCase       TestCase         @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  project        Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  executionResult ExecutionResult? @relation(fields: [executionResultId], references: [id], onDelete: SetNull)

  @@index([testCaseId])
  @@index([projectId])
  @@index([executionResultId])
  @@map("defects")
}

enum DefectSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum DefectStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

// SkillLog model for tracking user skills and improvements
model SkillLog {
  id          String   @id @default(cuid())
  userId      String
  skillName   String
  proficiency Int      // 1-10 scale
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("skill_logs")
}

// VideoAnalysis model for video processing and test extraction
model VideoAnalysis {
  id                    String   @id @default(cuid())
  clientId              String
  videoPath             String
  stepsExtracted        Int
  confidence            Float
  suggestedFramework    String
  extractedSteps        String   @db.Text  // JSON stringified
  createdAt             DateTime @default(now())

  client                Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("video_analyses")
}
